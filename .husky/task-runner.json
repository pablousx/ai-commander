{
   "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
   "tasks": [
      {
         "name": "commit-message-linter",
         "group": "commit-msg",
         "command": "dotnet",
         "args": [
            "commit-lint",
            "--commit-file",
            "${args}",
            "--commit-message-config-file",
            "commit-message-config.json"
         ]
      },
      {
         "name": "dotnet-format",
         "group": "pre-commit",
         "command": "dotnet",
         "args": ["format", "--verify-no-changes", "--severity", "error"]
      }
   ]
}
