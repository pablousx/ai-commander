{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "desktop: dev",
      "type": "process",
      "command": "pnpm",
      "args": ["desktop:dev"],
      "isBackground": true,
      "problemMatcher": [],
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "frontend: dev",
      "type": "process",
      "command": "pnpm",
      "args": ["dev"],
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "Local:.*1420"
        }
      }
    },
    {
      "label": "desktop: build",
      "type": "process",
      "command": "pnpm",
      "args": ["desktop:build"],
      "problemMatcher": []
    },
    {
      "label": "check",
      "type": "process",
      "command": "pnpm",
      "args": ["check"],
      "problemMatcher": [],
      "group": { "kind": "test", "isDefault": true }
    },
    {
      "label": "test: watch",
      "type": "process",
      "command": "pnpm",
      "args": ["test:watch"],
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
