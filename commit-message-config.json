{
  "config": {
    "max-subject-length": {
      "enabled": true,
      "value": 90
    },
    "conventional-commit": {
      "enabled": true,
      "types": [
        "feat",
        "fix",
        "refactor",
        "build",
        "chore",
        "ci",
        "style",
        "test",
        "docs",
        "perf",
        "revert"
      ],
      "scopes": {
        "enabled": false,
        "global": [],
        "per-type": {}
      }
    }
  }
}
