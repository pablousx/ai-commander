<Window x:Class="AICommander.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AICommander.App.Views"
        Title="AI Commander Configuration" Height="550" Width="700"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/logo.ico"
        Background="#F0F2F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,20">
            <TextBlock Text="App Configurations" FontSize="24" FontWeight="Bold" Foreground="#1A1A1A" VerticalAlignment="Center" />
            <Button Content="⚙️ Settings" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="10,5"
                    Background="#F3F3F3" Foreground="#333" FontWeight="SemiBold" BorderBrush="#CCC" BorderThickness="1" Cursor="Hand"
                    Click="Settings_Click" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,10">
            <StackPanel>
                <ItemsControl ItemsSource="{Binding AppSections}" x:Name="AppSectionsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <views:AppSectionControl />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                
                <Button Content="[add new app from a list or custom]" HorizontalAlignment="Left" Background="Transparent" 
                        BorderThickness="0" Foreground="#0078D4" Cursor="Hand" FontSize="14" Margin="0,10,0,20">
                    <Button.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="Antigravity" Command="{Binding AddAppCommand}" CommandParameter="antigravity" />
                            <MenuItem Header="VS Code" Command="{Binding AddAppCommand}" CommandParameter="vscode" />
                            <MenuItem Header="Claude" Command="{Binding AddAppCommand}" CommandParameter="claude" />
                            <Separator />
                            <MenuItem Header="Custom" Command="{Binding AddAppCommand}" CommandParameter="custom" />
                        </ContextMenu>
                    </Button.ContextMenu>
                    <Button.Style>
                        <Style TargetType="Button">
                            <EventSetter Event="Click" Handler="AddAppButton_Click"/>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Margin="-20,15,-20,-20" Padding="20,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="{Binding HintText}" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="#888" FontStyle="Italic" FontSize="13"/>
                <Button Content="Close" Width="100" Height="36" Click="Hide_Click" 
                        Background="#F3F3F3" Foreground="#333" FontWeight="SemiBold" BorderBrush="#CCC" BorderThickness="1" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
