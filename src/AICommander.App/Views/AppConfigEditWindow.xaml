<Window x:Class="AICommander.App.Views.AppConfigEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit App Configuration" SizeToContent="Height" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Assets/logo.ico"
        Background="#F0F2F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Icon *" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#333"/>
                    <Button Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand" ToolTip="Click to select an icon" Click="IconSelect_Click" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Border Width="32" Height="32" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Background="#F4F4F4">
                            <Image Source="{Binding Icon}" Stretch="Uniform" Margin="2" ImageFailed="IconImage_ImageFailed">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                                <Setter Property="Source" Value="pack://application:,,,/Assets/logo.ico" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Icon}" Value="">
                                                <Setter Property="Source" Value="pack://application:,,,/Assets/logo.ico" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Border>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="App Name *" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#333"/>
                    <TextBox x:Name="AppNameBox" Text="{Binding ProviderName, UpdateSourceTrigger=PropertyChanged}" Padding="5" Height="32" VerticalContentAlignment="Center"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="Process Name *" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#333"/>
            <TextBox x:Name="ProcessNameBox" Text="{Binding ProcessName, UpdateSourceTrigger=PropertyChanged}" Padding="5" Margin="0,0,0,10"/>

            <CheckBox x:Name="EnabledCheckBox" Content="Enabled" IsChecked="{Binding IsEnabled}" Margin="0,5,0,0" Foreground="#333" FontWeight="SemiBold"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Margin="-20,20,-20,-20" Padding="20,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="80" Height="30" Click="Cancel_Click" Margin="0,0,10,0"
                        Background="#F3F3F3" Foreground="#333" FontWeight="SemiBold" BorderBrush="#CCC" BorderThickness="1" Cursor="Hand"/>
                <Button Content="Save" Width="80" Height="30" Click="Save_Click" 
                        Background="#0078D4" Foreground="White" FontWeight="SemiBold" BorderBrush="#005A9E" BorderThickness="1" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
