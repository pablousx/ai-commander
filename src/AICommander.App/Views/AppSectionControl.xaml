<UserControl x:Class="AICommander.App.Views.AppSectionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AICommander.App.Views"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="800">
    <Border x:Name="RootBorder" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Margin="0,0,0,15">
        <Border.RenderTransform>
            <TranslateTransform x:Name="DragTransform" />
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" CornerRadius="8,8,0,0" Padding="15,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,15,0" VerticalAlignment="Center">
                        <TextBlock x:Name="DragHandle" Text="☰" FontSize="20" Foreground="#888" Cursor="SizeAll" 
                                   ToolTip="Drag to reorder" Margin="5,0,5,0" Background="Transparent"
                                   PreviewMouseLeftButtonDown="DragHandle_PreviewMouseLeftButtonDown"
                                   PreviewMouseMove="DragHandle_PreviewMouseMove"
                                   PreviewMouseLeftButtonUp="DragHandle_PreviewMouseLeftButtonUp" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="32" Height="32" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Background="#F4F4F4" Margin="0,0,10,0">
                            <Image Source="{Binding Icon}" Stretch="Uniform" Margin="2" ImageFailed="IconImage_ImageFailed">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                                <Setter Property="Source" Value="pack://application:,,,/Assets/logo.ico" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Icon}" Value="">
                                                <Setter Property="Source" Value="pack://application:,,,/Assets/logo.ico" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Border>
                        <TextBlock Text="{Binding ProviderName}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Foreground="#333" />
                        <TextBlock Text="{Binding ProcessName, StringFormat=' (\{0\})'}" FontSize="16" FontWeight="Normal" VerticalAlignment="Center" Foreground="#888" Margin="0,0,10,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ProcessName}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ProcessName}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Invalid Config" VerticalAlignment="Center" Foreground="#D9534F" FontWeight="SemiBold" Margin="0,0,15,0" ToolTip="Process name is required">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ProcessName}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ProcessName}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <TextBlock Text="Disabled" VerticalAlignment="Center" Foreground="#D9534F" FontWeight="SemiBold" Margin="0,0,15,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Button Content="Edit ⚙️" Command="{Binding DataContext.EditAppCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Foreground="#0078D4" FontWeight="SemiBold" Cursor="Hand" ToolTip="Edit App Configuration" Margin="0,0,15,0"/>

                        <Button Content="✕" Command="{Binding DataContext.RemoveAppCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Foreground="#D9534F" FontWeight="Bold" Cursor="Hand" ToolTip="Remove App"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Table Header -->
            <Grid Grid.Row="1" Margin="15,15,15,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="ACTION" FontWeight="SemiBold" Foreground="#888" FontSize="12"/>
                <TextBlock Grid.Column="1" Text="APP HOTKEY" FontWeight="SemiBold" Foreground="#888" FontSize="12"/>
                <TextBlock Grid.Column="2" Text="GLOBAL HOTKEY" FontWeight="SemiBold" Foreground="#888" FontSize="12"/>
            </Grid>
            
            <!-- Table Body -->
            <ItemsControl Grid.Row="2" ItemsSource="{Binding Actions}" Margin="15,0,15,15">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#EEEEEE" BorderThickness="0,1,0,0" Padding="0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Margin="0,0,10,0">
                                    <TextBox x:Name="ActionNameBox" Text="{Binding ActionName, UpdateSourceTrigger=PropertyChanged}" 
                                             VerticalAlignment="Center" Padding="5,4" Background="Transparent" BorderBrush="#DDD" 
                                             GotFocus="ActionNameBox_GotFocus" LostFocus="ActionNameBox_LostFocus"
                                             PreviewKeyDown="ActionNameBox_PreviewKeyDown" PreviewMouseLeftButtonUp="ActionNameBox_PreviewMouseLeftButtonUp" />
                                             
                                    <Popup IsOpen="{Binding IsSuggestionsOpen, Mode=TwoWay}" PlacementTarget="{Binding ElementName=ActionNameBox}" Placement="Bottom" StaysOpen="False">
                                        <Border Background="White" BorderBrush="#CCC" BorderThickness="1" CornerRadius="4" MaxHeight="200" MinWidth="{Binding ActualWidth, ElementName=ActionNameBox}">
                                            <ListBox ItemsSource="{Binding SuggestedActionsView}" BorderThickness="0" Background="Transparent" 
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="ActionSuggestion_SelectionChanged">
                                                <ListBox.GroupStyle>
                                                    <GroupStyle>
                                                        <GroupStyle.HeaderTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#888" Background="#F0F0F0" Padding="5,2"/>
                                                            </DataTemplate>
                                                        </GroupStyle.HeaderTemplate>
                                                    </GroupStyle>
                                                </ListBox.GroupStyle>
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Action}" Padding="5,2" Cursor="Hand"/>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                    
                                    <TextBlock Text="{Binding Index, StringFormat=Action \{0\}}" 
                                               IsHitTestVisible="False" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="#AAA"
                                               FontStyle="Italic">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=ActionNameBox}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Text, ElementName=ActionNameBox}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                
                                <local:HotkeyCaptureControl Grid.Column="1" Text="{Binding AppHotkey, UpdateSourceTrigger=Explicit}" 
                                                            VerticalAlignment="Center" Margin="0,0,10,0" Padding="5,4" Background="#F4F4F4" BorderBrush="#DDD" />

                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0">
                                    <local:HotkeyCaptureControl Text="{Binding GlobalHotkey, UpdateSourceTrigger=Explicit}" 
                                                                Padding="5,4" Background="#F4F4F4" BorderBrush="#DDD"/>
                                    <TextBlock Text="Duplicate Global Hotkey" Foreground="#D9534F" FontSize="11" Margin="0,2,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDuplicateGlobalHotkey}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="System Hotkey Conflict" Foreground="#D9534F" FontSize="11" Margin="0,2,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSystemGlobalHotkeyConflict}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                
                                <Button Grid.Column="3" Content="⋮" Click="ActionOptionsButton_Click" Background="Transparent" BorderThickness="0" Foreground="#888" FontWeight="Bold" FontSize="18" Cursor="Hand" ToolTip="Action Options" Margin="5,0,0,0" Padding="8,4" MinWidth="30" Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Reset to Default" Command="{Binding PlacementTarget.Tag.ResetActionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}" />
                                            <Separator />
                                            <MenuItem Header="Delete Action" Foreground="#D9534F" Command="{Binding PlacementTarget.Tag.RemoveActionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}" />
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Add Action Button -->
            <Button Grid.Row="3" Content="[add new]" Command="{Binding AddActionCommand}" 
                    HorizontalAlignment="Left" Margin="15,0,0,15" Background="Transparent" 
                    BorderThickness="0" Foreground="#0078D4" Cursor="Hand" FontSize="12"/>
        </Grid>
    </Border>
</UserControl>
