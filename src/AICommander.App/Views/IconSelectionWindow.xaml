<Window x:Class="AICommander.App.Views.IconSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Icon" Height="400" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Assets/logo.ico"
        Background="#F0F2F5">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Choose an App Icon" FontSize="18" FontWeight="Bold" Foreground="#1A1A1A" Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15" Background="White" BorderBrush="#DDD" BorderThickness="1" Padding="10">
            <ItemsControl x:Name="IconItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Background="Transparent" BorderBrush="#EEE" BorderThickness="1" Margin="5" Padding="5" Cursor="Hand" Click="Icon_Click" ToolTip="Select this icon">
                            <Image Source="{Binding}" Width="48" Height="48" Stretch="Uniform" />
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Margin="-15,0,-15,-15" Padding="15,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="➕ Add Custom Icon" Height="32" Padding="10,0" Click="AddCustomIcon_Click" Margin="0,0,10,0"
                        Background="#0078D4" Foreground="White" FontWeight="SemiBold" BorderBrush="#005A9E" BorderThickness="1" Cursor="Hand"/>
                <Button Content="Cancel" Width="80" Height="32" Click="Cancel_Click" 
                        Background="#F3F3F3" Foreground="#333" FontWeight="SemiBold" BorderBrush="#CCC" BorderThickness="1" Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
